{
  "name": "@promethean-os/opencode-unified",
  "version": "0.1.0",
  "description": "Unified OpenCode client with ClojureScript editor and Electron integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./electron": {
      "types": "./dist/electron/index.d.ts",
      "import": "./dist/electron/index.js",
      "require": "./dist/electron/index.cjs"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs"
    },
    "./plugins/*": {
      "import": "./dist/plugins/*.js",
      "require": "./dist/plugins/*.cjs"
    },
    "./dist/*": "./dist/*",
    "./*": "./dist/*"
  },
  "bin": {
    "opencode-unified": "dist/cli.js"
  },
  "files": [
    "dist",
    "static",
    "electron-builder.json"
  ],
  "scripts": {
    "build": "pnpm build:clojurescript",
    "build:clojurescript": "shadow-cljs release app",
    "build:tests": "shadow-cljs compile test",
    "clean": "rimraf dist",
    "typecheck": "shadow-cljs check app renderer",
    "typecheck:clojurescript": "shadow-cljs check app renderer preload main server",
    "test": "npx ava src/tests/**/*.test.ts",
    "test:unit": "ava tests/unit/**/*.test.ts",
    "test:integration": "ava tests/integration/**/*.test.ts",
    "test:e2e": "run-s test:e2e:sanity test:playwright",
    "test:e2e:sanity": "ava tests/e2e/**/*.test.ts",
    "test:playwright": "playwright test",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:debug": "playwright test --debug",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:install": "playwright install",
    "test:watch": "ava --watch",
    "test:coverage": "c8 ava",
    "test:clojurescript": "shadow-cljs compile test && node target/test.cjs",
    "test:clojurescript:coverage": "shadow-cljs compile test && c8 node --enable-source-maps target/test.cjs",
    "test:all": "pnpm test && pnpm test:clojurescript",
    "lint": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "pnpm exec prettier --write .",
    "dev": "pnpm dev:clojurescript",
    "dev:clojurescript": "shadow-cljs watch app renderer preload main",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "start": "pnpm build && electron .",
    "start:electron": "pnpm build && electron .",
    "electron:pack": "pnpm build && electron-builder --dir",
    "electron:dist": "pnpm build && electron-builder",
    "web-ui": "node src/clojurescript/electron/web-ui/server.js"
  },
  "keywords": [
    "opencode",
    "electron",
    "clojurescript",
    "llm",
    "agent",
    "cli",
    "editor"
  ],
  "author": "Promethean Team",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@promethean-os/openplanner-cljs-client": "file:../../../packages/openplanner-cljs-client",
    "@promethean-os/opencode-cljs-client": "file:../../../packages/opencode-cljs-client",
    "@opencode-ai/plugin": "^0.15.7",
    "@opencode-ai/sdk": "^0.15.7",
    "zod": "^3.25.76",
    "dotenv": "^17.2.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "ora": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "scheduler": "^0.27.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "ava": "^6.1.3",
    "c8": "^9.1.0",
    "sinon": "^18.0.0",
    "chokidar": "^3.6.0",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^24.13.3",
    "npm-run-all": "^4.1.5",
    "shadow-cljs": "^2.28.23",
    "rimraf": "^5.0.5",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "@playwright/test": "^1.48.0"
  },
  "build": {
    "appId": "ai.promethean.opencode-unified",
    "productName": "Promethean OpenCode",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "static/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "static",
        "to": "static"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "workspaces": {
    "packages": [
      "src/clojurescript/*"
    ]
  }
}
