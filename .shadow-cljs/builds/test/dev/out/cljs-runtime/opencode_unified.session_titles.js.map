(ns opencode-unified.session-titles
  "Fetch session titles from OpenCode SDK without circular deps"
  (:require ["@opencode-ai/sdk/client" :refer [createOpencodeClient]]
            [clojure.string :as str]))

(declare ensure-client sdk-response->result response-error)

(defn- backend-config []
  (or (some-> js/window (aget "__WORKBENCH_BACKENDS__") (js->clj :keywordize-keys true)) {}))

(defn- configured-api-endpoint []
  (let [cfg (backend-config)]
    (or (:opencode-url cfg)
        (:opencodeUrl cfg)
        "http://localhost:8788/api/opencode")))

(defn- configured-api-key []
  (let [cfg (backend-config)]
    (or (:opencode-api-key cfg)
        (:opencodeApiKey cfg)
        (:openplanner-api-key cfg)
        (:openplannerApiKey cfg))))

(defn- make-client [endpoint]
  (let [api-key (configured-api-key)
        headers (cond-> {}
                  (some? api-key) (assoc "Authorization" (str "Bearer " api-key)))]
    (createOpencodeClient (clj->js {:baseUrl endpoint :headers headers}))))

(defn- ensure-client []
  (let [endpoint (configured-api-endpoint)
        clients (atom {})]
    (or (get @clients endpoint)
        (let [client (make-client endpoint)]
          (swap! clients assoc endpoint client)
          client))))

(defn- sdk-response->result [response]
  (let [result (js->clj response :keywordize-keys true)
        data (:data result)
        error (or (:error result)
                  (get-in result [:error :message]))]
    (if error
      {:error (if (string? error) error (str error))}
      (or data result))))

(defn- response-error [error]
  (if (string? error)
    error
    (or (.-message error) (str error))))

(defn list-opencode-sessions []
  "List all OpenCode sessions and return them with proper titles"
  (let [client (ensure-client)
        session-api (.-session client)
        list-fn (.-list session-api)]
    (if (not list-fn)
      (do
        (println "SDK session.list() method not available, using OpenPlanner titles only")
        (js/Promise.resolve {}))
      (-> (.call list-fn session-api (clj->js {}))
          (.then (fn [result]
                   (let [normalized (sdk-response->result result)]
                     (if-let [error (:error normalized)]
                       (do (println "Failed to list OpenCode sessions:" error) {})
                       (let [sessions (or (:sessions normalized) (:data normalized) [])]
                         (into {} (map (fn [s]
                                         (let [sid (or (:id s) (:sessionID s) (:session-id s))
                                               title (or (:title s) (:name s) "Untitled Session")]
                                           [sid title])))
                               sessions))))))
          (.catch (fn [error]
                    (println "Error fetching OpenCode sessions:" (response-error error))
                    {}))))))
