(ns test-opencode
  (:require [clojure.test :refer [deftest is testing]]
            [opencode-unified.opencode :as opencode]
            [opencode-unified.state :as state]
            [reagent.core :as r]))

(deftest test-sdk-response-normalization
  (testing "sdk-response->result"
    (is (= {:foo "bar"} (#'opencode/sdk-response->result #js {:data #js {:foo "bar"}})))
    (is (= {:error "failed"} (#'opencode/sdk-response->result #js {:error "failed"})))
    (is (= {:error "failed"} (#'opencode/sdk-response->result #js {:error #js {:message "failed"}})))
    ;; Vector handling
    (is (= [1 2 3] (#'opencode/sdk-response->result #js {:data #js [1 2 3]})))))

(deftest test-chat-logic
  (testing "append-chat-message!"
    (reset! opencode/opencode-state {:chat-stream []})
    (#'opencode/append-chat-message! :user "hello")
    (let [stream (:chat-stream @opencode/opencode-state)]
      (is (= 1 (count stream)))
      (is (= :user (:role (first stream))))
      (is (= "hello" (:text (first stream)))))))

(deftest test-prompt-logic
  (testing "prompt-title-from"
    (is (= "My Title" (#'opencode/prompt-title-from nil {:title "My Title"})))
    (is (= "Question?" (#'opencode/prompt-title-from nil {:question "Question?"})))
    (is (= "Input requested: path/to/res" (#'opencode/prompt-title-from "path/to/res" {}))))

  (testing "queue-control-prompt!"
    (reset! opencode/opencode-state {:pending-prompts []})
    (#'opencode/queue-control-prompt! "path" {:id "p1" :title "Test"})
    (let [prompts (:pending-prompts @opencode/opencode-state)]
      (is (= 1 (count prompts)))
      (is (= "p1" (:id (first prompts)))))))

(deftest test-client-setup
  (testing "backend-config with window"
    (let [orig-window (when (exists? js/window) js/window)]
      (set! js/window #js {:__WORKBENCH_BACKENDS__ #js {:opencodeUrl "http://test"}})
      (try
        (is (= "http://test" (#'opencode/configured-api-endpoint)))
        (finally
          (set! js/window orig-window)))))

  (testing "backend-config without window"
    (let [orig-window (when (exists? js/window) js/window)]
      (set! js/window nil)
      (try
        (is (= "http://localhost:8788/api/opencode" (#'opencode/configured-api-endpoint)))
        (finally
          (set! js/window orig-window))))))
